<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Kristalball Full Test Suite" parallel="false">

    <!-- Register Listener -->
    <listeners>
        <listener class-name="listeners.TestListener"/>
    </listeners>

    <test name="All Functional Tests">

        <classes>
            <!-- Landing Page -->
            <class name="tests.LandingPageTest"/>

            <!-- Navigation Flow -->
            <class name="tests.CompleteNavigationTest"/>

            <!-- Age Verification -->
            <class name="tests.AgeVerificationTest"/>

            <!-- Feedback Form Validation -->
            <class name="tests.FeedbackFormValidationTest"/>

            <!-- Login and Reg Validation -->
            <class name="tests.LoginTest"/>
            <class name="tests.RegistrationTest"/>

        </classes>

    </test>

</suite>